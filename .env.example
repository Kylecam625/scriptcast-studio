# Enables deterministic demo mode without external API calls.
SCRIPTCAST_MOCK_MODE=true

# OpenAI is used server-side for strict structured parsing when mock mode is off.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# ElevenLabs is used server-side for voice search and Text to Dialogue when mock mode is off.
ELEVENLABS_API_KEY=
ELEVENLABS_DIALOGUE_MODEL=eleven_v3
ELEVENLABS_SOUND_EFFECT_MODEL=eleven_text_to_sound_v2
ELEVENLABS_TIMEOUT_MS=90000
ELEVENLABS_MAX_CONCURRENCY=3

# Optional override if ffmpeg is not on PATH.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MEDIA_TOOL_TIMEOUT_MS=120000
SFX_BACKGROUND_VOLUME=0.35

# Optional override for generated project/audio storage.
# On macOS, use a non-iCloud location to avoid dataless/offloaded audio files.
SCRIPTCAST_STORAGE_DIR=

# Optional. Set this before exposing the app publicly.
SCRIPTCAST_ACCESS_CODE=
